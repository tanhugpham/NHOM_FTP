<Window x:Class="FileTransfer.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Secure File Transfer"
        Width="1060"
        Height="700"
        MinWidth="860"
        MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Background="#1C2333"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>

        <!--
        ══ PALETTE ══════════════════════════════════════
          BG        #1C2333  slate-navy background
          Surface   #242D42  card / panel surface
          Raised    #2C3650  elevated elements, inputs
          Border    #3A4560  borders / dividers
          Muted     #7A8BAA  secondary text
          Subtle    #B0BBCC  body text
          Text      #E2E8F0  primary text
          White     #F8FAFC  headings / emphasis
          Accent    #6C8EF0  indigo — interactive elements
          Green     #4ADE80  success / upload
          Red       #F87171  danger / logout
          Gold      #FBBF24  warning (share code)
        ════════════════════════════════════════════════ -->

        <!-- TextBox / PasswordBox -->
        <Style TargetType="TextBox">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Background"      Value="#2C3650"/>
            <Setter Property="Foreground"      Value="#E2E8F0"/>
            <Setter Property="CaretBrush"      Value="#E2E8F0"/>
            <Setter Property="BorderBrush"     Value="#3A4560"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SelectionBrush"  Value="#6C8EF0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Background"      Value="#2C3650"/>
            <Setter Property="Foreground"      Value="#E2E8F0"/>
            <Setter Property="CaretBrush"      Value="#E2E8F0"/>
            <Setter Property="BorderBrush"     Value="#3A4560"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SelectionBrush"  Value="#6C8EF0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>

        <!-- Primary button -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Background"      Value="#2C3650"/>
            <Setter Property="Foreground"      Value="#B0BBCC"/>
            <Setter Property="BorderBrush"     Value="#3A4560"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A4560"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#48567A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button — indigo -->
        <Style x:Key="BtnAccent" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background"  Value="#3D4E7A"/>
            <Setter Property="Foreground"  Value="#A5B4FC"/>
            <Setter Property="BorderBrush" Value="#6C8EF0"/>
        </Style>

        <!-- Danger button -->
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background"  Value="#3D2828"/>
            <Setter Property="Foreground"  Value="#F87171"/>
            <Setter Property="BorderBrush" Value="#F87171"/>
        </Style>

        <!-- Success button -->
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background"  Value="#1E3A2A"/>
            <Setter Property="Foreground"  Value="#4ADE80"/>
            <Setter Property="BorderBrush" Value="#4ADE80"/>
        </Style>

        <!-- Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="#242D42"/>
            <Setter Property="BorderBrush"     Value="#3A4560"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="18,16"/>
            <Setter Property="Margin"          Value="0,0,0,10"/>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="9.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#7A8BAA"/>
            <Setter Property="Margin"     Value="0,0,0,12"/>
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#7A8BAA"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="#1C2333"/>
            <Setter Property="Foreground"               Value="#E2E8F0"/>
            <Setter Property="BorderBrush"              Value="#3A4560"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="RowBackground"            Value="#1C2333"/>
            <Setter Property="AlternatingRowBackground" Value="#212B3E"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2C3650"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="RowHeight"                Value="30"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#242D42"/>
            <Setter Property="Foreground"      Value="#7A8BAA"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="10,7"/>
            <Setter Property="BorderBrush"     Value="#3A4560"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3D4E7A"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2C3650"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground"      Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="10,0" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#F8FAFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ProgressBar -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height"          Value="4"/>
            <Setter Property="Background"      Value="#3A4560"/>
            <Setter Property="Foreground"      Value="#6C8EF0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="#1C2333"/>
            <Setter Property="Foreground"      Value="#7A8BAA"/>
            <Setter Property="BorderBrush"     Value="#3A4560"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="0"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding"    Value="10,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7A8BAA"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#242D42"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2C3650"/>
                    <Setter Property="Foreground" Value="#E2E8F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- ═══════════════════════════════ -->
        <!--  ALERT OVERLAY                  -->
        <!-- ═══════════════════════════════ -->
        <Grid x:Name="AlertOverlay" Visibility="Collapsed" Panel.ZIndex="999">
            <Grid Background="#99111827"/>
            <Border Background="#242D42"
                    BorderBrush="#3A4560"
                    BorderThickness="1"
                    Width="380"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="36,32">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="48" Height="48"
                            Background="#1E3A2A"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <TextBlock Text="✓"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#4ADE80"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock x:Name="AlertTitle"
                               Text="Login Successful"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#F8FAFC"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="AlertMessage"
                               Text="Welcome back"
                               FontSize="13"
                               Foreground="#7A8BAA"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,28"/>

                    <Button x:Name="btnAlertOk"
                            Content="Continue"
                            Style="{StaticResource BtnAccent}"
                            Width="140"
                            Height="34"
                            Click="btnAlertOk_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════ -->
        <!--  LOGIN SCREEN                   -->
        <!-- ═══════════════════════════════ -->
        <Grid x:Name="LoginPanel" Background="#1C2333">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- Left hero -->
            <Grid Grid.Column="0">
                <Border Width="3" HorizontalAlignment="Left" Background="#6C8EF0"/>

                <StackPanel VerticalAlignment="Center" Margin="60,0,40,0">

                    <TextBlock Text="SECURE FILE TRANSFER"
                               FontSize="9"
                               FontWeight="Bold"
                               Foreground="#7A8BAA"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Move files with confidence."
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="#F8FAFC"
                               TextWrapping="Wrap"
                               LineHeight="44"/>

                    <Border Width="40" Height="1"
                            Background="#6C8EF0"
                            HorizontalAlignment="Left"
                            Margin="0,24,0,24"/>

                    <TextBlock Text="AES-256 encryption · Resume upload · Real-time sync · Private storage"
                               FontSize="13"
                               Foreground="#7A8BAA"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </StackPanel>
            </Grid>

            <!-- Right login panel -->
            <Border Grid.Column="1"
                    Background="#242D42"
                    BorderBrush="#3A4560"
                    BorderThickness="1,0,0,0"
                    Padding="40,0">
                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="SIGN IN"
                               Style="{StaticResource SectionHead}"
                               Margin="0,0,0,4"/>

                    <TextBlock Text="Connect and authenticate"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#F8FAFC"
                               Margin="0,0,0,32"/>

                    <TextBlock Text="Server IP" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtServerIp" Text="127.0.0.1" Margin="0,0,0,12"/>

                    <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtPort" Text="9000" Margin="0,0,0,14"/>

                    <Button x:Name="btnConnect"
                            Content="Connect to Server"
                            Style="{StaticResource BtnPrimary}"
                            Click="btnConnect_Click"
                            Margin="0,0,0,28"/>

                    <Border Height="1" Background="#3A4560" Margin="0,0,0,24"/>

                    <TextBlock Text="Username" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtUsername" Margin="0,0,0,12"/>

                    <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="txtPassword" Margin="0,0,0,22"/>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnRegister"
                                Grid.Column="0"
                                Content="Register"
                                Style="{StaticResource BtnPrimary}"
                                Click="btnRegister_Click"/>

                        <Button x:Name="btnLogin"
                                Grid.Column="2"
                                Content="Login"
                                Style="{StaticResource BtnAccent}"
                                Click="btnLogin_Click"/>
                    </Grid>

                    <TextBlock x:Name="txtStatus"
                               Text="● Disconnected"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#F87171"
                               HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════ -->
        <!--  MAIN SCREEN                    -->
        <!-- ═══════════════════════════════ -->
        <Grid x:Name="MainPanel" Visibility="Collapsed" Background="#1C2333">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Background="#242D42">
                <Border Width="3" HorizontalAlignment="Left" Background="#6C8EF0"/>

                <DockPanel Margin="20,0" LastChildFill="False">

                    <StackPanel Orientation="Vertical"
                                VerticalAlignment="Center"
                                DockPanel.Dock="Left">
                        <TextBlock Text="Secure File Transfer"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#F8FAFC"/>
                        <TextBlock Text="AES-256 · Real-time · Encrypted"
                                   FontSize="10"
                                   Foreground="#7A8BAA"/>
                    </StackPanel>

                    <Button x:Name="btnDisconnect"
                            Content="✕"
                            Style="{StaticResource BtnDanger}"
                            Width="32" Height="28"
                            DockPanel.Dock="Right"
                            Click="btnDisconnect_Click"
                            ToolTip="Disconnect"
                            Padding="0" FontSize="13"/>

                    <Button x:Name="btnLogout"
                            Content="Logout"
                            Style="{StaticResource BtnDanger}"
                            Width="90" Height="28"
                            DockPanel.Dock="Right"
                            Click="btnLogout_Click"
                            Margin="0,0,8,0"/>

                    <TextBlock x:Name="txtCurrentUser"
                               Text="—"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#B0BBCC"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"
                               DockPanel.Dock="Right"/>
                </DockPanel>
            </Grid>

            <Border Grid.Row="1" Background="#3A4560"/>

            <!-- BODY -->
            <Grid Grid.Row="2" Margin="16,12,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Upload -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="UPLOAD" Style="{StaticResource SectionHead}"/>

                                <Button x:Name="btnBrowse"
                                        Content="Choose Files"
                                        Style="{StaticResource BtnPrimary}"
                                        Click="btnBrowse_Click"
                                        Margin="0,0,0,10"/>

                                <TextBox x:Name="txtSelectedFile"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         Height="50"
                                         Margin="0,0,0,10"/>

                                <Button x:Name="btnUpload"
                                        Content="Upload Selected Files"
                                        Style="{StaticResource BtnSuccess}"
                                        Click="btnUpload_Click"
                                        Margin="0,0,0,12"/>

                                <ProgressBar x:Name="progressUpload"
                                             Minimum="0" Maximum="100"
                                             Margin="0,0,0,6"/>

                                <TextBlock x:Name="txtProgress"
                                           Text="0%"
                                           FontSize="11"
                                           Foreground="#7A8BAA"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>

                        <!-- Secure Sharing -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="SECURE SHARING" Style="{StaticResource SectionHead}"/>

                                <TextBlock Text="Allowed user" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtAllowedUsername" Margin="0,0,0,10"/>

                                <Button x:Name="btnCreateShareCode"
                                        Content="Create Share Code"
                                        Style="{StaticResource BtnAccent}"
                                        Click="btnCreateShareCode_Click"
                                        Margin="0,0,0,12"/>

                                <TextBlock Text="Generated code" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtShareCodeResult" IsReadOnly="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Receive Shared -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="RECEIVE SHARED FILE" Style="{StaticResource SectionHead}"/>

                                <TextBlock Text="Share code" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtInputShareCode" Margin="0,0,0,10"/>

                                <Button x:Name="btnDownloadSharedFile"
                                        Content="Download Shared File"
                                        Style="{StaticResource BtnPrimary}"
                                        Click="btnDownloadSharedFile_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- RIGHT PANEL -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="160"/>
                    </Grid.RowDefinitions>

                    <!-- File list -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="MY FILES"
                                           Style="{StaticResource SectionHead}"
                                           Margin="0,2,0,0"
                                           DockPanel.Dock="Left"/>

                                <Button x:Name="btnRefreshFiles"
                                        Content="Refresh"
                                        Style="{StaticResource BtnPrimary}"
                                        Width="90" Height="28"
                                        DockPanel.Dock="Right"
                                        Click="btnRefreshFiles_Click"/>
                            </DockPanel>

                            <DataGrid x:Name="dgServerFiles" Grid.Row="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="File Name"
                                                        Binding="{Binding FileName}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="Size"
                                                        Binding="{Binding FileSize}"
                                                        Width="110"/>
                                    <DataGridTextColumn Header="Uploaded At"
                                                        Binding="{Binding UploadedAt}"
                                                        Width="160"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <DockPanel Grid.Row="2" Margin="0,12,0,0" LastChildFill="True">
                                <Button x:Name="btnDownload"
                                        Content="Download Selected"
                                        Style="{StaticResource BtnPrimary}"
                                        Width="160" Height="30"
                                        DockPanel.Dock="Left"
                                        Click="btnDownload_Click"
                                        Margin="0,0,12,0"/>

                                <TextBlock x:Name="txtDownloadProgress"
                                           Text="0%"
                                           FontSize="11"
                                           Foreground="#7A8BAA"
                                           Width="36"
                                           VerticalAlignment="Center"
                                           DockPanel.Dock="Right"
                                           Margin="8,0,0,0"/>

                                <ProgressBar x:Name="progressDownload"
                                             Minimum="0" Maximum="100"
                                             VerticalAlignment="Center"
                                             Margin="0,4,0,0"/>
                            </DockPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"/>

                    <!-- Activity Logs -->
                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="ACTIVITY LOG"
                                           Style="{StaticResource SectionHead}"
                                           Margin="0,2,0,0"
                                           DockPanel.Dock="Left"/>

                                <Button x:Name="btnOpenRequests"
                                        Content="Requests (0)"
                                        Style="{StaticResource BtnAccent}"
                                        Width="110" Height="26"
                                        DockPanel.Dock="Right"
                                        Click="btnOpenRequests_Click"/>
                            </DockPanel>

                            <ListBox x:Name="lstLogs" Grid.Row="1"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="3" Background="#3A4560"/>

            <!-- FOOTER -->
            <Grid Grid.Row="4" Background="#242D42">
                <TextBlock Text="Not connected to server"
                           FontSize="10"
                           Foreground="#7A8BAA"
                           VerticalAlignment="Center"
                           Margin="20,0"/>
            </Grid>
        </Grid>

    </Grid>
</Window>
