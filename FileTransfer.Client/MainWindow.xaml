<Window x:Class="FileTransfer.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Secure File Transfer Client"
        Width="1200"
        Height="850"
        MinWidth="1000"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">

        <!-- LOGIN SCREEN -->
        <Grid x:Name="LoginPanel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="520"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="40">
                <TextBlock Text="Secure File Transfer"
                           FontSize="42"
                           FontWeight="Bold"
                           Foreground="#1E3A8A"/>

                <TextBlock Text="Client - Server realtime file transfer"
                           FontSize="20"
                           Margin="0,12,0,0"
                           Foreground="#475569"/>

                <TextBlock Text="Private storage, AES encryption, resume upload, multi-file and secure sharing."
                           FontSize="15"
                           TextWrapping="Wrap"
                           Width="520"
                           Margin="0,24,0,0"
                           Foreground="#64748B"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="22"
                    Padding="34"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Welcome Back"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Connect and login to continue"
                               FontSize="14"
                               Foreground="#64748B"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,28"/>

                    <TextBlock Text="Server IP"/>
                    <TextBox x:Name="txtServerIp"
                             Text="127.0.0.1"
                             Margin="0,6,0,14"/>

                    <TextBlock Text="Port"/>
                    <TextBox x:Name="txtPort"
                             Text="9000"
                             Margin="0,6,0,18"/>

                    <Button x:Name="btnConnect"
                            Content="Connect to Server"
                            Click="btnConnect_Click"
                            Margin="0,0,0,22"/>

                    <TextBlock Text="Username"/>
                    <TextBox x:Name="txtUsername"
                             Margin="0,6,0,14"/>

                    <TextBlock Text="Password"/>
                    <PasswordBox x:Name="txtPassword"
                                 Margin="0,6,0,22"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnRegister"
                                Grid.Column="0"
                                Content="Register"
                                Background="#0F766E"
                                Click="btnRegister_Click"/>

                        <Button x:Name="btnLogin"
                                Grid.Column="2"
                                Content="Login"
                                Background="#2563EB"
                                Click="btnLogin_Click"/>
                    </Grid>

                    <TextBlock x:Name="txtStatus"
                               Text="Status: Disconnected"
                               Foreground="#1D4ED8"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,24,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- MAIN SCREEN -->
        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <Grid MinHeight="720">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="66"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <Border Grid.Row="0"
                            Background="#0F172A"
                            CornerRadius="18"
                            Padding="20,0"
                            Margin="0,0,0,14">
                        <DockPanel LastChildFill="False">

                            <StackPanel Orientation="Vertical"
                                        VerticalAlignment="Center"
                                        DockPanel.Dock="Left">
                                <TextBlock Text="Secure File Transfer"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="Private storage, AES encryption, resume upload, secure sharing"
                                           FontSize="12"
                                           Foreground="#CBD5E1"/>
                            </StackPanel>

                            <Button x:Name="btnDisconnect"
                                    Content="Disconnect"
                                    Width="130"
                                    Background="#DC2626"
                                    DockPanel.Dock="Right"
                                    Click="btnDisconnect_Click"/>

                            <TextBlock x:Name="txtCurrentUser"
                                       Text="User: -"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Margin="0,0,20,0"
                                       DockPanel.Dock="Right"/>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT PANEL -->
                        <StackPanel Grid.Column="0">

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Upload Files"
                                               Style="{StaticResource SectionTitle}"/>

                                    <Button x:Name="btnBrowse"
                                            Content="Choose Files"
                                            Background="#2563EB"
                                            Click="btnBrowse_Click"/>

                                    <TextBox x:Name="txtSelectedFile"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             Height="62"
                                             Margin="0,10,0,10"/>

                                    <Button x:Name="btnUpload"
                                            Content="Upload Selected Files"
                                            Background="#16A34A"
                                            Click="btnUpload_Click"/>

                                    <ProgressBar x:Name="progressUpload"
                                                 Height="20"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Margin="0,12,0,6"/>

                                    <TextBlock x:Name="txtProgress"
                                               Text="0%"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Secure Sharing"
                                               Style="{StaticResource SectionTitle}"/>

                                    <TextBlock Text="Allowed username"
                                               Foreground="#475569"/>
                                    <TextBox x:Name="txtAllowedUsername"
                                             Margin="0,5,0,8"/>

                                    <Button x:Name="btnCreateShareCode"
                                            Content="Create Share Code"
                                            Background="#7C3AED"
                                            Click="btnCreateShareCode_Click"/>

                                    <TextBlock Text="Generated share code"
                                               Foreground="#475569"
                                               Margin="0,12,0,0"/>
                                    <TextBox x:Name="txtShareCodeResult"
                                             IsReadOnly="True"
                                             Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Receive Shared File"
                                               Style="{StaticResource SectionTitle}"/>

                                    <TextBlock Text="Share code"
                                               Foreground="#475569"/>
                                    <TextBox x:Name="txtInputShareCode"
                                             Margin="0,5,0,10"/>

                                    <Button x:Name="btnDownloadSharedFile"
                                            Content="Download Shared File"
                                            Background="#EA580C"
                                            Click="btnDownloadSharedFile_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- RIGHT PANEL -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="145"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0"
                                               Margin="0,0,0,12">
                                        <TextBlock Text="My Private Files"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   DockPanel.Dock="Left"/>

                                        <Button x:Name="btnRefreshFiles"
                                                Content="Refresh"
                                                Width="110"
                                                Background="#334155"
                                                DockPanel.Dock="Right"
                                                Click="btnRefreshFiles_Click"/>
                                    </DockPanel>

                                    <DataGrid x:Name="dgServerFiles"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              SelectionMode="Single"
                                              GridLinesVisibility="Horizontal"
                                              HeadersVisibility="Column"
                                              RowHeight="32"
                                              AlternatingRowBackground="#F8FAFC">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="File Name"
                                                                Binding="{Binding FileName}"
                                                                Width="*"/>
                                            <DataGridTextColumn Header="Size"
                                                                Binding="{Binding FileSize}"
                                                                Width="130"/>
                                            <DataGridTextColumn Header="Uploaded At"
                                                                Binding="{Binding UploadedAt}"
                                                                Width="180"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <DockPanel Grid.Row="2"
                                               Margin="0,12,0,0">
                                        <Button x:Name="btnDownload"
                                                Content="Download Selected"
                                                Width="170"
                                                Background="#0284C7"
                                                DockPanel.Dock="Left"
                                                Click="btnDownload_Click"/>

                                        <TextBlock x:Name="txtDownloadProgress"
                                                   Text="0%"
                                                   FontWeight="Bold"
                                                   Width="50"
                                                   Margin="12,8,0,0"
                                                   DockPanel.Dock="Right"/>

                                        <ProgressBar x:Name="progressDownload"
                                                     Height="20"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Margin="16,8,0,0"/>
                                    </DockPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    Style="{StaticResource Card}"
                                    Margin="0,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Activity Logs"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,0,0,8"/>

                                    <ListBox x:Name="lstLogs"
                                             Grid.Row="1"
                                             BorderBrush="#E2E8F0"
                                             Background="#F8FAFC"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>