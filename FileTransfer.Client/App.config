<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <appSettings>
    <!-- mTLS: Client certificate paths -->
    <add key="ClientCertificatePath" value="Certificates\client.pfx" />
    <add key="CACertificatePath" value="Certificates\ca.cer" />
    <add key="ClientCertPassword" value="Client123!" />
    <!-- AES Encryption (loaded by Shared library) -->
    <add key="AesKey" value="9O8PXJjMGiJ2cRhYZDUb6WEerQIUQJDqKfz8WfDX04M=" />
    <add key="AesIV" value="J+V3uWb8gvhNPobZTqFD0g==" />
  </appSettings>
</configuration>